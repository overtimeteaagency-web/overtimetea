# Copy to .env and fill in values:
#   cp .env.example .env
#
# Run (loads this file automatically):
#   pnpm run dev        — API + frontend
#   pnpm run dev:web    — frontend only
#   pnpm run dev:api    — API only (port 8080)
#   pnpm run db:push    — sync DB tables

# PostgreSQL (required for API + drizzle push)
DATABASE_URL=postgresql://user:password@localhost:5432/overtimetea

# Frontend dev server (artifacts/overtime-tea)
PORT=5173
BASE_PATH=/

# API server (artifacts/api-server) — override PORT in that shell:
#   PORT=8080 pnpm --filter @workspace/api-server run dev

# Optional
# LOG_LEVEL=info
