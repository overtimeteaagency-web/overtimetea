{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev": "node scripts/run-dev.mjs",
    "dev:web": "node scripts/with-env.mjs -- pnpm --filter @workspace/overtime-tea run dev",
    "dev:api": "node scripts/with-env.mjs -- sh -c \"PORT=8080 pnpm --filter @workspace/api-server run dev\"",
    "db:push": "node scripts/with-env.mjs -- pnpm --filter @workspace/db run push",
    "db:push:force": "node scripts/with-env.mjs -- pnpm --filter @workspace/db run push-force"
  },
  "private": true,
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.4",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.3.0",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
